{
  "name": "@duskdomains/sdk",
  "version": "0.1.6",
  "license": "MIT",
  "exports": {
    ".": "./src/index.ts",
    "./internal": "./src/internal.ts",
    "./writes": "./src/writes.ts",
    "./connect": "./src/connect.ts",
    "./local-dev": "./src/local-dev.ts",
    "./write-proof": "./src/write-proof.ts",
