{
  "name": "@duskdomains/sdk",
  "version": "0.1.6",
  "license": "MIT",
  "type": "module",
  "description": "TypeScript SDK and integration helpers for Dusk Domains.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./internal": {
      "types": "./src/internal.ts",
      "import": "./src/internal.ts"
    },
    "./writes": {
      "types": "./src/writes.ts",
      "import": "./src/writes.ts"
    },
    "./write-proof": {
      "types": "./src/write-proof.ts",
      "import": "./src/write-proof.ts"
    },
    "./marketplace": {
      "types": "./src/marketplace.ts",
      "import": "./src/marketplace.ts"
    },
    "./event-catalog": {
      "types": "./src/indexer/events/indexerEventCatalog.d.mts",
      "import": "./src/indexer/events/indexerEventCatalog.mjs"
    }
  },
  "files": [
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.test.mjs",
    "!src/**/*test-fixtures*",
    "!src/connect.ts",
    "!src/local-dev.ts",
    "!src/wallet",
    "!src/dev",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "jsr:dry-run": "npx jsr publish --dry-run",
    "prepare": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0"
  },
  "devDependencies": {
    "@dusk/connect": "npm:@jsr/dusk__connect@^0.2.0",
    "@dusk/w3sper": "npm:@jsr/dusk__w3sper@^1.6.0",
    "@types/node": "^24.12.3",
    "typescript": "~6.0.2",
    "vitest": "^4.1.9"
  }
}
